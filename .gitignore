# Rust build output (generated by cargo; not committed — Cargo.lock is kept).
/target/
**/*.rs.bk
*.pdb

# Coverage / profiling artifacts.
*.profraw
/coverage/
/llvm-cov-target/

# Environment / secrets (tokens and endpoints are passed via env, never committed).
.env
.env.*

# Internal planning notes (not part of the published SDK).
/planning/

# Local tooling / editor config.
.claude/
.idea/
.vscode/
*.iml

# OS junk.
.DS_Store
Thumbs.db
